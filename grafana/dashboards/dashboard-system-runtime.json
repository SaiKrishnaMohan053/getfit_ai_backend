{
  "uid": "system-runtime",
  "title": "System & Runtime Health",
  "tags": ["system", "nodejs", "runtime"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Backend Uptime (sec)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "backend_uptime_seconds", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage (seconds)",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 6 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[1m])", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory RSS (MB)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node.js Heap Used (MB)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag (ms)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_p99_seconds * 1000",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC Duration (ms)",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum[5m]) * 1000",
          "refId": "A"
        }
      ]
    }
  ]
}