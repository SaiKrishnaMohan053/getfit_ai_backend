{
  "uid": "getfit-ai-backend-metrics",
  "title": "GetFit AI – Backend Observability (Linked)",
  "tags": ["getfit", "ai", "backend", "observability"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 42,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "links": [
    {
      "title": "← Back to Overview",
      "type": "dashboard",
      "keepTime": true,
      "targetBlank": true,
      "url": "/d/getfit_health_v1"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Redis Cache",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "type": "timeseries",
      "title": "Redis Hits vs Misses (rate)",
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_cache_hits_total[5m])", "legendFormat": "hits", "refId": "A" },
        { "expr": "rate(redis_cache_misses_total[5m])", "legendFormat": "misses", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops" }
      },
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Redis Hit Ratio (since start)",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_cache_hits_total / (redis_cache_hits_total + redis_cache_misses_total)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      },
      "gridPos": { "x": 0, "y": 9, "w": 6, "h": 4 }
    },

    {
      "type": "row",
      "title": "BullMQ Queue Stats",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 }
    },
    {
      "type": "timeseries",
      "title": "BullMQ Completed / Failed (rate)",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(bullmq_jobs_completed[5m])", "legendFormat": "completed", "refId": "A" },
        { "expr": "rate(bullmq_jobs_failed[5m])", "legendFormat": "failed", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "jobs" }
      },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 }
    },
    {
      "type": "stat",
      "title": "BullMQ Active Jobs",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "bullmq_jobs_active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" } }
      },
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 4 }
    },

    {
      "type": "row",
      "title": "OpenAI + HTTP",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 }
    },
    {
      "type": "timeseries",
      "title": "OpenAI Response Time (p95)",
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(openai_response_time_ms_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests by Route",
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "req/s" } },
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 }
    },

    {
      "type": "row",
      "title": "Runtime Health (Node.js)",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 }
    },
    {
      "type": "timeseries",
      "title": "Heap Usage (MB)",
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes / 1024 / 1024", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "megabytes" } },
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag (seconds)",
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "nodejs_eventloop_lag_seconds", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 }
    }
  ]
}