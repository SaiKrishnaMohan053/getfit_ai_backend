{
  "family": "getfit-ai-staging-task",

  "networkMode": "awsvpc",

  "requiresCompatibilities": ["FARGATE"],

  "cpu": "512",
  "memory": "1024",

  "executionRoleArn": "arn:aws:iam::180294195589:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::180294195589:role/getfit-ai-taskRole",

  "containerDefinitions": [
    {
      "name": "backend",

      "image": "180294195589.dkr.ecr.us-east-1.amazonaws.com/getfit_ai_backend:latest",

      "essential": true,

      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "NODE_ENV", "value": "staging" },
        { "name": "PORT", "value": "8080" },

        { "name": "ENABLE_METRICS", "value": "true" },
        { "name": "ENABLE_BACKGROUND_JOBS", "value": "true" },

        { "name": "QDRANT_COLLECTION", "value": "getfit_staging" },

        { "name": "REDIS_HOST", "value": "getfit-redis-9y9aob.serverless.use1.cache.amazonaws.com" },
        { "name": "REDIS_PORT", "value": "6379" },

        { "name": "STAGING_BASE_URL", "value": "http://localhost:8080" }
      ],

      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:180294195589:secret:getfit-ai-staging-openai-key-6W2L6R"
        },
        {
          "name": "QDRANT_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:180294195589:secret:getfit-ai-staging-qdrant-api-8VUD3S"
        },
        {
          "name": "QDRANT_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:180294195589:secret:getfit-ai-staging-qdrant-url-J85Z3c"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:180294195589:secret:getfit-ai-redis-yF90ZJ"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/getfit-ai-staging",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      },

      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8080/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      }
    }
  ]
}