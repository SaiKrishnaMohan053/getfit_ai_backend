{
  "family": "getfit-backend-task",

  "networkMode": "awsvpc", 

  "requiresCompatibilities": ["FARGATE"],

  "cpu": "2048",
  "memory": "4096",

  "executionRoleArn": "arn:aws:iam::879519940213:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::879519940213:role/getfit-ai-taskRole",

  "containerDefinitions": [
    {
      "name": "backend",

      "image": "879519940213.dkr.ecr.us-east-1.amazonaws.com/getfit_ai_backend:IMAGE_TAG",

      "essential": true,

      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "8080" },

        { "name": "ENABLE_METRICS", "value": "true" },
        { "name": "ENABLE_BACKGROUND_JOBS", "value": "true" },

        { "name": "DIAGRAM_SERVICE_URL", "value": "http://localhost:8000" },
        { "name": "QDRANT_COLLECTION", "value": "ecs_test" },

        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "AWS_TRAINING_BUCKET", "value": "getfit-ai-training-pdfs" },

        { "name": "STAGING_BASE_URL", "value": "http://localhost:8080" }
      ],

      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:879519940213:secret:getfit-ai-backend-secrets-LB2bwi:OPENAI_API_KEY::"
        },
        {
          "name": "QDRANT_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:879519940213:secret:getfit-ai-backend-secrets-LB2bwi:QDRANT_URL::"
        },
        {
          "name": "REDIS_HOST",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:879519940213:secret:getfit-ai-backend-secrets-LB2bwi:REDIS_HOST::"
        },
        {
          "name": "REDIS_PORT",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:879519940213:secret:getfit-ai-backend-secrets-LB2bwi:REDIS_PORT::"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:879519940213:secret:getfit-ai-backend-secrets-LB2bwi:REDIS_PASSWORD::"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/getfit-backend-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    },
    {
      "name": "diagram-service",
      "image": "879519940213.dkr.ecr.us-east-1.amazonaws.com/getfit_ai_diagram:IMAGE_TAG",
      "essential": false,

      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "DIAGRAM_SERVICE_URL", "value": "http://localhost:8000" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "AWS_TRAINING_BUCKET", "value": "getfit-ai-training-pdfs" }
      ],

      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/getfit-backend-task",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "diagram"
        }
      }
    }
  ]
}